# Local development (.env) — copy to .env and fill in values.
EXPO_PUBLIC_FIREBASE_ENV=development
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=promptfund.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=promptfund
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=promptfund.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# EAS / TestFlight production builds:
# These same EXPO_PUBLIC_FIREBASE_* variables must be set as EAS secrets (or build env)
# so app.config.ts can embed them into expo.extra.firebase at build time.
#
# Example:
#   eas secret:create --scope project --name EXPO_PUBLIC_FIREBASE_API_KEY --value "..."
#   eas secret:create --scope project --name EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID --value "..."
#   eas secret:create --scope project --name EXPO_PUBLIC_FIREBASE_APP_ID --value "..."
#
# Then rebuild: eas build --platform ios --profile production
