rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function discussionRoom(roomId) {
      return firestore.get(/databases/(default)/documents/discussionRooms/$(roomId));
    }

    function isDiscussionRoomParticipant(roomId) {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/discussionRooms/$(roomId))
        && (
          discussionRoom(roomId).data.founderId == request.auth.uid
          || discussionRoom(roomId).data.investorId == request.auth.uid
          || isAdmin()
        );
    }

    function canWriteDiscussionAttachment(roomId, userId) {
      return isSignedIn()
        && request.auth.uid == userId
        && isDiscussionRoomParticipant(roomId);
    }

    function agreementRoom(agreementId) {
      return firestore.get(/databases/(default)/documents/agreementRooms/$(agreementId));
    }

    function hasAgreementAccess(agreementId) {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/agreementRooms/$(agreementId))
        && (
          agreementRoom(agreementId).data.founderId == request.auth.uid
          || agreementRoom(agreementId).data.investorId == request.auth.uid
          || request.auth.uid in agreementRoom(agreementId).data.adminIds
          || isAdmin()
        );
    }

    match /users/{userId}/profile.jpg {
      allow read: if request.auth != null;
      allow write, delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /startup-images/{userId}/{imageName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /agreements/{agreementId}/{artifactName} {
      allow read, write: if hasAgreementAccess(agreementId);
    }

    match /support-tickets/{userId}/{ticketId}/{fileName} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // discussion-attachments/{roomId}/{userId}/{fileName}
    // roomId must match discussionRooms/{roomId} in Firestore.
    // userId must match request.auth.uid (uploader owns their folder).
    match /discussion-attachments/{roomId}/{userId}/{fileName} {
      allow read: if isDiscussionRoomParticipant(roomId);
      allow create: if canWriteDiscussionAttachment(roomId, userId);
      allow update: if canWriteDiscussionAttachment(roomId, userId);
      allow delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
