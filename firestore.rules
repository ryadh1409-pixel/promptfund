rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function agreementRoom(agreementId) {
      return get(/databases/$(database)/documents/agreementRooms/$(agreementId));
    }

    function hasAgreementAccess(agreementId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/agreementRooms/$(agreementId))
        && (
          isAdmin()
          ||
          agreementRoom(agreementId).data.founderId == request.auth.uid
          || agreementRoom(agreementId).data.investorId == request.auth.uid
          || request.auth.uid in agreementRoom(agreementId).data.adminIds
        );
    }

    function createsOwnAgreementRoom() {
      return isSignedIn()
        && (
          request.resource.data.founderId == request.auth.uid
          || request.resource.data.investorId == request.auth.uid
          || request.auth.uid in request.resource.data.adminIds
        );
    }

    function isBlockedBetween(firstUid, secondUid) {
      return exists(/databases/$(database)/documents/blockedUsers/$(firstUid + '_' + secondUid))
        || exists(/databases/$(database)/documents/blockedUsers/$(secondUid + '_' + firstUid));
    }

    function blockIdIncludesSignedInUser(blockId) {
      return isSignedIn()
        && (
          blockId.matches(request.auth.uid + '_.*')
          || blockId.matches('.*_' + request.auth.uid)
        );
    }

    function blockResourceIncludesSignedInUser() {
      return isSignedIn()
        && resource != null
        && (
          resource.data.blockerUid == request.auth.uid
          || resource.data.blockedUid == request.auth.uid
        );
    }

    function blockDocumentHasExpectedSchema() {
      return request.resource.data.keys().hasOnly([
          'blockerUid',
          'blockedUid',
          'blockerName',
          'blockedName',
          'blockerRole',
          'blockedRole',
          'blockedPhotoURL',
          'createdAt'
        ])
        && request.resource.data.blockerUid is string
        && request.resource.data.blockedUid is string
        && request.resource.data.blockerName is string
        && request.resource.data.blockedName is string
        && request.resource.data.blockerRole in ['Founder', 'Angel Investor']
        && request.resource.data.blockedRole in ['Founder', 'Angel Investor']
        && (!request.resource.data.keys().hasAny(['blockedPhotoURL']) || request.resource.data.blockedPhotoURL is string)
        && request.resource.data.createdAt is string;
    }

    function createsOwnBlockDocument(blockId) {
      return isSignedIn()
        && blockDocumentHasExpectedSchema()
        && request.resource.data.blockerUid == request.auth.uid
        && blockId == request.auth.uid + '_' + request.resource.data.blockedUid;
    }

    function updatesOwnBlockDocument(blockId) {
      return isSignedIn()
        && resource != null
        && blockDocumentHasExpectedSchema()
        && resource.data.blockerUid == request.auth.uid
        && request.resource.data.blockerUid == resource.data.blockerUid
        && request.resource.data.blockedUid == resource.data.blockedUid
        && blockId == resource.data.blockerUid + '_' + resource.data.blockedUid;
    }

    function canReadBlockDocument(blockId) {
      return isSignedIn()
        && (
          blockResourceIncludesSignedInUser()
          || (resource == null && blockIdIncludesSignedInUser(blockId))
        );
    }

    function reportDocumentHasExpectedSchema() {
      return request.resource.data.keys().hasOnly([
          'reporterUid',
          'reportedUid',
          'discussionRoomId',
          'reason',
          'details',
          'createdAt',
          'status'
        ])
        && request.resource.data.reporterUid is string
        && request.resource.data.reportedUid is string
        && request.resource.data.discussionRoomId is string
        && request.resource.data.reason in [
          'Spam',
          'Scam or Fraud',
          'Bad language',
          'False Investment Information',
          'Other'
        ]
        && request.resource.data.details is string
        && request.resource.data.createdAt is string
        && request.resource.data.status == 'pending';
    }

    function messageReportDocumentHasExpectedSchema() {
      return request.resource.data.keys().hasOnly([
          'reporterId',
          'reportedUserId',
          'roomId',
          'messageId',
          'reason',
          'details',
          'createdAt',
          'status'
        ])
        && request.resource.data.reporterId is string
        && request.resource.data.reportedUserId is string
        && request.resource.data.roomId is string
        && request.resource.data.messageId is string
        && request.resource.data.reason in [
          'Harassment',
          'Hate Speech',
          'Scam / Fraud',
          'Spam',
          'Sexual Content',
          'Threats',
          'Other'
        ]
        && request.resource.data.details is string
        && request.resource.data.createdAt is string
        && request.resource.data.status == 'pending';
    }

    function messageReportIdBelongsToReporter(reportId) {
      return isSignedIn() && reportId.matches('^.*_' + request.auth.uid + '$');
    }

    function senderSoftDeletesOwnMessage() {
      return isSignedIn()
        && resource != null
        && resource.data.senderId == request.auth.uid
        && request.resource.data.senderId == resource.data.senderId
        && request.resource.data.deleted == true
        && request.resource.data.text == ''
        && request.resource.data.body == '';
    }

    function participantUpdatesDeliveryStateOnly() {
      return isSignedIn()
        && resource != null
        && isDiscussionRoomParticipant(resource.data.discussionRoomId)
        && resource.data.senderId != request.auth.uid
        && request.resource.data.senderId == resource.data.senderId
        && request.resource.data.discussionRoomId == resource.data.discussionRoomId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'deliveredAt',
          'readAt',
          'updatedAt'
        ])
        && request.resource.data.status in ['delivered', 'read']
        && resource.data.status in ['sent', 'delivered', 'read'];
    }

    function reportIdBelongsToSignedInReporter(reportId) {
      return isSignedIn() && reportId.matches('^.*_' + request.auth.uid + '$');
    }

    function supportTicketHasExpectedSchema() {
      return request.resource.data.keys().hasOnly([
          'ticketNumber',
          'userId',
          'userName',
          'userEmail',
          'subject',
          'category',
          'message',
          'attachments',
          'status',
          'priority',
          'unreadByAdmin',
          'unreadByUser',
          'lastMessageAt',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.ticketNumber is string
        && request.resource.data.ticketNumber.matches('^PF-[0-9]{8}-[0-9]{6}$')
        && request.resource.data.userId is string
        && request.resource.data.userName is string
        && request.resource.data.userEmail is string
        && request.resource.data.subject is string
        && request.resource.data.subject.size() > 0
        && request.resource.data.category in [
          'Account',
          'Verification',
          'Funding',
          'Investments',
          'Payments',
          'Technical Issue',
          'Report a User',
          'Report a Bug',
          'Feature Request',
          'Other'
        ]
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.attachments is list
        && request.resource.data.status == 'Open'
        && request.resource.data.priority == 'Normal'
        && request.resource.data.unreadByAdmin == true
        && request.resource.data.unreadByUser == false
        && request.resource.data.lastMessageAt is timestamp
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function supportTicketUpdateHasExpectedSchema() {
      return request.resource.data.keys().hasOnly([
          'ticketNumber',
          'userId',
          'userName',
          'userEmail',
          'subject',
          'category',
          'message',
          'attachments',
          'status',
          'priority',
          'unreadByAdmin',
          'unreadByUser',
          'lastMessageAt',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.ticketNumber == resource.data.ticketNumber
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.userName == resource.data.userName
        && request.resource.data.userEmail == resource.data.userEmail
        && request.resource.data.subject == resource.data.subject
        && request.resource.data.category == resource.data.category
        && request.resource.data.message == resource.data.message
        && request.resource.data.attachments == resource.data.attachments
        && request.resource.data.status in ['Open', 'Waiting for User', 'In Progress', 'Resolved', 'Closed']
        && request.resource.data.priority == resource.data.priority
        && request.resource.data.unreadByAdmin is bool
        && request.resource.data.unreadByUser is bool
        && request.resource.data.lastMessageAt is timestamp
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt is timestamp;
    }

    function supportMessageHasExpectedSchema() {
      return request.resource.data.keys().hasOnly([
          'senderId',
          'senderRole',
          'text',
          'attachments',
          'createdAt'
        ])
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.senderRole in ['user', 'admin']
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.attachments is list
        && request.resource.data.createdAt is timestamp;
    }

    function ownsSupportTicket(ticketId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/supportTickets/$(ticketId))
        && get(/databases/$(database)/documents/supportTickets/$(ticketId)).data.userId == request.auth.uid;
    }

    function ownsSupportTicketAfter(ticketId) {
      return isSignedIn()
        && existsAfter(/databases/$(database)/documents/supportTickets/$(ticketId))
        && getAfter(/databases/$(database)/documents/supportTickets/$(ticketId)).data.userId == request.auth.uid;
    }

    function projectOwner(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId;
    }

    function opportunityOwner(opportunityId) {
      return exists(/databases/$(database)/documents/startupOpportunities/$(opportunityId))
        ? get(/databases/$(database)/documents/startupOpportunities/$(opportunityId)).data.founderId
        : get(/databases/$(database)/documents/investmentOpportunities/$(opportunityId)).data.founderId;
    }

    function startupOwner(startupId) {
      return exists(/databases/$(database)/documents/projects/$(startupId))
        ? projectOwner(startupId)
        : opportunityOwner(startupId);
    }

    function startupExists(startupId) {
      return exists(/databases/$(database)/documents/projects/$(startupId))
        || exists(/databases/$(database)/documents/startupOpportunities/$(startupId))
        || exists(/databases/$(database)/documents/investmentOpportunities/$(startupId));
    }

    function createsV5ParticipantDocument() {
      return isSignedIn()
        && (
          request.resource.data.founderId == request.auth.uid
          || request.resource.data.investorId == request.auth.uid
        );
    }

    function isLinkedAgreementInvestment(investmentId) {
      return exists(/databases/$(database)/documents/agreements/$(investmentId));
    }

    function linkedAgreementParticipantData(investmentId) {
      return get(/databases/$(database)/documents/agreements/$(investmentId)).data;
    }

    function investmentParticipantData(data) {
      return data.founderId == request.auth.uid || data.investorId == request.auth.uid;
    }

    function isInvestmentFounder() {
      return isSignedIn()
        && resource != null
        && resource.data.keys().hasAny(['founderId'])
        && resource.data.founderId == request.auth.uid;
    }

    function isInvestmentInvestor() {
      return isSignedIn()
        && resource != null
        && resource.data.keys().hasAny(['investorId'])
        && resource.data.investorId == request.auth.uid;
    }

    function canListInvestment() {
      return isAdmin() || isInvestmentFounder() || isInvestmentInvestor();
    }

    function canAccessInvestmentAsParticipant(investmentId) {
      return isSignedIn() && (
        (
          exists(/databases/$(database)/documents/investments/$(investmentId))
          && investmentParticipantData(get(/databases/$(database)/documents/investments/$(investmentId)).data)
        )
        || (
          isLinkedAgreementInvestment(investmentId)
          && investmentParticipantData(linkedAgreementParticipantData(investmentId))
        )
      );
    }

    function canCreateInvestmentAsParticipant() {
      return isSignedIn() && investmentParticipantData(request.resource.data);
    }

    function canUpdateInvestmentAsParticipant(investmentId) {
      return isSignedIn()
        && investmentParticipantData(request.resource.data)
        && (
          (
            exists(/databases/$(database)/documents/investments/$(investmentId))
            && investmentParticipantData(resource.data)
          )
          || (
            isLinkedAgreementInvestment(investmentId)
            && investmentParticipantData(linkedAgreementParticipantData(investmentId))
          )
        );
    }

    function linkedInvestmentInvestorId(investmentId) {
      return exists(/databases/$(database)/documents/investments/$(investmentId))
        ? get(/databases/$(database)/documents/investments/$(investmentId)).data.investorId
        : linkedAgreementParticipantData(investmentId).investorId;
    }

    function isInvestmentParticipant(investmentId) {
      return canAccessInvestmentAsParticipant(investmentId);
    }

    function ownsInvestmentAsFounder(investmentId) {
      return isSignedIn() && (
        (
          exists(/databases/$(database)/documents/investments/$(investmentId))
          && get(/databases/$(database)/documents/investments/$(investmentId)).data.founderId == request.auth.uid
        )
        || (
          isLinkedAgreementInvestment(investmentId)
          && linkedAgreementParticipantData(investmentId).founderId == request.auth.uid
        )
      );
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == userId);

      match /blocked/{blockedUid} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create, update: if isSignedIn()
          && request.auth.uid == userId
          && request.resource.data.keys().hasOnly([
            'blockedUid',
            'blockedName',
            'blockedRole',
            'blockedPhotoURL',
            'createdAt',
            'removedAt'
          ]);
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /projects/{projectId} {
      allow read: if isSignedIn() || isAdmin();
      allow create: if isSignedIn()
        && (
          (
            request.resource.data.ownerId == request.auth.uid
            && request.resource.data.developerId == request.auth.uid
          )
          || request.resource.data.ownerId == request.auth.uid
          || request.resource.data.founderId == request.auth.uid
        );
      allow update, delete: if isAdmin()
        || (
          isSignedIn()
          && (
            resource.data.ownerId == request.auth.uid
            || resource.data.founderId == request.auth.uid
          )
        );
    }

    match /fundingRequests/{requestId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.requestedBy == request.auth.uid);
    }

    match /investments/{investmentId} {
      allow create: if isSignedIn()
        && (
          (
            request.resource.data.projectId != null
            && exists(/databases/$(database)/documents/projects/$(request.resource.data.projectId))
            && !isBlockedBetween(request.auth.uid, projectOwner(request.resource.data.projectId))
          )
          || canCreateInvestmentAsParticipant()
        );
      allow get: if isAdmin() || canAccessInvestmentAsParticipant(investmentId);
      allow list: if canListInvestment();
      allow update: if isAdmin() || canUpdateInvestmentAsParticipant(investmentId);
      allow delete: if isAdmin();
    }

    match /investmentOpportunities/{opportunityId} {
      allow read: if isSignedIn() || isAdmin();
      allow create: if isSignedIn() && request.resource.data.founderId == request.auth.uid;
      allow update: if isAdmin()
        || (
          isSignedIn()
          && (
            resource.data.founderId == request.auth.uid
            || request.resource.data.status in [
              'discussion_started',
              'ready_for_agreement',
              'agreement_pending',
              'awaiting_funding',
              'funding_arranged',
              'awaiting_payment',
              'funded',
              'completed',
              'archived',
              'frozen',
              'suspended',
              'deleted'
            ]
          )
        );
      allow delete: if isAdmin() || (isSignedIn() && resource.data.founderId == request.auth.uid);
    }

    match /startupOpportunities/{opportunityId} {
      allow read: if isSignedIn() || isAdmin();
      allow create: if isSignedIn() && request.resource.data.founderId == request.auth.uid;
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.founderId == request.auth.uid)
        || (
          isSignedIn()
          && request.resource.data.status in [
            'discussion_started',
            'ready',
            'ready_for_agreement',
            'agreement_pending',
            'awaiting_funding',
            'funding_arranged',
            'funded',
            'completed',
            'archived',
            'frozen',
            'suspended',
            'deleted'
          ]
        );
      allow delete: if isAdmin() || (isSignedIn() && resource.data.founderId == request.auth.uid);
    }

    function isDiscussionRoomParticipant(roomId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/discussionRooms/$(roomId))
        && (
          get(/databases/$(database)/documents/discussionRooms/$(roomId)).data.founderId == request.auth.uid
          || get(/databases/$(database)/documents/discussionRooms/$(roomId)).data.investorId == request.auth.uid
        );
    }

    match /discussionRooms/{roomId} {
      allow create: if request.auth != null
        && (
          request.resource.data.investorId == request.auth.uid
          || request.resource.data.founderId == request.auth.uid
        );
      allow read: if isAdmin()
        || (
          isSignedIn()
          && (
            resource.data.founderId == request.auth.uid
            || resource.data.investorId == request.auth.uid
          )
        );
      allow update: if isDiscussionRoomParticipant(roomId);
      allow delete: if isAdmin();
    }

    match /discussionMessages/{messageId} {
      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid
        && exists(/databases/$(database)/documents/discussionRooms/$(request.resource.data.discussionRoomId))
        && (
          get(/databases/$(database)/documents/discussionRooms/$(request.resource.data.discussionRoomId)).data.founderId == request.auth.uid
          || get(/databases/$(database)/documents/discussionRooms/$(request.resource.data.discussionRoomId)).data.investorId == request.auth.uid
        )
        && !isBlockedBetween(
          get(/databases/$(database)/documents/discussionRooms/$(request.resource.data.discussionRoomId)).data.founderId,
          get(/databases/$(database)/documents/discussionRooms/$(request.resource.data.discussionRoomId)).data.investorId
        );
      allow read: if isAdmin()
        || (
          isSignedIn()
          && exists(/databases/$(database)/documents/discussionRooms/$(resource.data.discussionRoomId))
          && (
            get(/databases/$(database)/documents/discussionRooms/$(resource.data.discussionRoomId)).data.founderId == request.auth.uid
            || get(/databases/$(database)/documents/discussionRooms/$(resource.data.discussionRoomId)).data.investorId == request.auth.uid
          )
        );
      allow update: if isAdmin()
        || senderSoftDeletesOwnMessage()
        || participantUpdatesDeliveryStateOnly()
        || (
          isSignedIn()
          && resource.data.senderId == request.auth.uid
          && isDiscussionRoomParticipant(resource.data.discussionRoomId)
        );
      allow delete: if isAdmin();
    }

    match /interests/{interestId} {
      allow create: if isSignedIn()
        && request.resource.data.investorId == request.auth.uid
        && request.resource.data.interestId == interestId
        && request.resource.data.status == 'interested'
        && startupExists(request.resource.data.startupOpportunityId)
        && request.resource.data.founderId == startupOwner(request.resource.data.startupOpportunityId)
        && !isBlockedBetween(request.auth.uid, request.resource.data.founderId);
      allow read: if isAdmin()
        || (isSignedIn() && (
          resource.data.investorId == request.auth.uid
          || resource.data.founderId == request.auth.uid
        ));
      allow update: if isAdmin()
        || (
          isSignedIn()
          && (
            resource.data.founderId == request.auth.uid
            || resource.data.investorId == request.auth.uid
          )
          && request.resource.data.status in ['discussion', 'accepted', 'expired']
        );
      allow delete: if isAdmin();
    }

    match /investmentInterests/{interestId} {
      allow create: if isSignedIn()
        && request.resource.data.investorId == request.auth.uid
        && request.resource.data.status == 'interested'
        && startupExists(request.resource.data.startupId)
        && request.resource.data.founderUid == startupOwner(request.resource.data.startupId)
        && !isBlockedBetween(request.auth.uid, request.resource.data.founderUid);
      allow read: if isAdmin()
        || (isSignedIn() && (
          resource.data.investorId == request.auth.uid
          || resource.data.founderUid == request.auth.uid
        ));
      allow update: if isAdmin()
        || (
          isSignedIn()
          && (
            resource.data.founderUid == request.auth.uid
            || resource.data.investorId == request.auth.uid
          )
          && request.resource.data.status in ['accepted', 'expired']
        );
      allow delete: if false;
    }

    match /matches/{matchId} {
      allow create: if isSignedIn()
        && (
          request.resource.data.founderUid == request.auth.uid
          || request.resource.data.investorUid == request.auth.uid
        )
        && startupExists(request.resource.data.startupId)
        && request.resource.data.founderUid == startupOwner(request.resource.data.startupId)
        && !isBlockedBetween(request.resource.data.founderUid, request.resource.data.investorUid);
      allow read, update: if isAdmin()
        || (isSignedIn() && (
          resource.data.founderUid == request.auth.uid
          || resource.data.investorUid == request.auth.uid
        ));
      allow delete: if isAdmin();
    }

    match /blockedUsers/{blockId} {
      allow create: if createsOwnBlockDocument(blockId);
      allow read: if canReadBlockDocument(blockId);
      allow update: if updatesOwnBlockDocument(blockId);
      allow delete: if isSignedIn()
        && resource != null
        && resource.data.blockerUid == request.auth.uid;
    }

    match /userReports/{reportId} {
      allow create: if isSignedIn() && request.resource.data.reporterUid == request.auth.uid;
      allow read, update: if isAdmin() || (isSignedIn() && resource.data.reporterUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /moderationFlags/{flagId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    match /adminAnnouncements/{announcementId} {
      allow create, delete: if isAdmin();
      allow read: if isSignedIn();
      allow update: if isAdmin()
        || (
          isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy'])
          && request.auth.uid in request.resource.data.readBy
        );
    }

    match /notifications/{notificationId} {
      allow create: if isAdmin() || isSignedIn();
      allow read, update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /pushTokens/{tokenId} {
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /legalConfig/{configId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /supportTicketCounters/{dateKey} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['count', 'updatedAt'])
        && request.resource.data.count == 1
        && request.resource.data.updatedAt is timestamp;
      allow update: if isSignedIn()
        && request.resource.data.keys().hasOnly(['count', 'updatedAt'])
        && resource.data.count is number
        && request.resource.data.count == resource.data.count + 1
        && request.resource.data.updatedAt is timestamp;
      allow delete: if isAdmin();
    }

    match /supportTickets/{ticketId} {
      allow create: if isSignedIn()
        && supportTicketHasExpectedSchema()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'Open';
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if supportTicketUpdateHasExpectedSchema()
        && (
          isAdmin()
          || (
            isSignedIn()
            && resource.data.userId == request.auth.uid
            && (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['unreadByUser'])
              || (
                request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                  'status',
                  'unreadByAdmin',
                  'unreadByUser',
                  'lastMessageAt',
                  'updatedAt'
                ])
                && request.resource.data.status == 'Open'
                && request.resource.data.unreadByAdmin == true
                && request.resource.data.unreadByUser == false
              )
            )
          )
        );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow create: if isSignedIn()
          && supportMessageHasExpectedSchema()
          && (
            (request.resource.data.senderRole == 'admin' && isAdmin())
            || (request.resource.data.senderRole == 'user' && ownsSupportTicketAfter(ticketId))
          );
        allow read: if isAdmin() || ownsSupportTicket(ticketId);
        allow update, delete: if isAdmin();
      }
    }

    match /activityTimeline/{eventId} {
      allow create: if isAdmin() || isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /founderUpdates/{updateId} {
      allow create: if isSignedIn()
        && request.resource.data.founderId == request.auth.uid
        && ownsInvestmentAsFounder(request.resource.data.investmentId)
        && request.resource.data.investorId == linkedInvestmentInvestorId(request.resource.data.investmentId);
      allow read: if isAdmin()
        || (
          isSignedIn()
          && (
            resource.data.founderId == request.auth.uid
            || resource.data.investorId == request.auth.uid
          )
        );
      allow update: if isAdmin()
        || (
          isSignedIn()
          && resource.data.founderId == request.auth.uid
          && request.resource.data.founderId == resource.data.founderId
          && request.resource.data.investorId == resource.data.investorId
          && request.resource.data.investmentId == resource.data.investmentId
        );
      allow delete: if isAdmin() || (isSignedIn() && resource.data.founderId == request.auth.uid);
    }

    match /founderUpdateComments/{commentId} {
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && isInvestmentParticipant(request.resource.data.investmentId)
        && (
          request.resource.data.founderId == request.auth.uid
          || request.resource.data.investorId == request.auth.uid
        );
      allow read: if isAdmin()
        || (
          isSignedIn()
          && (
            resource.data.founderId == request.auth.uid
            || resource.data.investorId == request.auth.uid
          )
        );
      allow update: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if isSignedIn()
        && reportDocumentHasExpectedSchema()
        && reportId == request.resource.data.discussionRoomId + '_' + request.auth.uid
        && request.resource.data.reporterUid == request.auth.uid;
      allow read: if isAdmin()
        || (
          isSignedIn()
          && (
            reportIdBelongsToSignedInReporter(reportId)
            || (resource != null && resource.data.reporterUid == request.auth.uid)
          )
        );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /messageReports/{reportId} {
      allow create: if isSignedIn()
        && messageReportDocumentHasExpectedSchema()
        && reportId == request.resource.data.messageId + '_' + request.auth.uid
        && request.resource.data.reporterId == request.auth.uid;
      allow read: if isAdmin()
        || (
          isSignedIn()
          && (
            messageReportIdBelongsToReporter(reportId)
            || (resource != null && resource.data.reporterId == request.auth.uid)
          )
        );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /agreementRooms/{agreementId} {
      allow create: if createsOwnAgreementRoom();
      allow read, update: if isAdmin() || hasAgreementAccess(agreementId);
      allow delete: if isAdmin();
    }

    match /agreements/{agreementId} {
      allow create: if createsOwnAgreementRoom() || createsV5ParticipantDocument();
      allow read, update: if isAdmin()
        || hasAgreementAccess(agreementId)
        || (
          isSignedIn()
          && resource != null
          && (
            resource.data.founderId == request.auth.uid
            || resource.data.investorId == request.auth.uid
          )
        );
      allow delete: if isAdmin();
    }

    match /investmentContracts/{agreementId} {
      allow create, read, update: if isAdmin() || hasAgreementAccess(agreementId);
      allow delete: if false;
    }

    match /investmentContractVersions/{versionId} {
      allow create: if isSignedIn() && hasAgreementAccess(request.resource.data.agreementId);
      allow read: if isAdmin() || hasAgreementAccess(resource.data.agreementId);
      allow update, delete: if false;
    }

    match /agreementMeetings/{meetingId} {
      allow create: if isSignedIn() && hasAgreementAccess(request.resource.data.agreementId);
      allow read, update: if isAdmin() || hasAgreementAccess(resource.data.agreementId);
      allow delete: if false;
    }

    match /agreementParticipants/{participantId} {
      allow create: if isSignedIn() && hasAgreementAccess(request.resource.data.agreementId);
      allow read, update: if isAdmin() || hasAgreementAccess(resource.data.agreementId);
      allow delete: if false;
    }

    match /agreementTranscripts/{transcriptId} {
      allow create: if isSignedIn() && hasAgreementAccess(request.resource.data.agreementId);
      allow read, update: if isAdmin() || hasAgreementAccess(resource.data.agreementId);
      allow delete: if false;
    }

    match /agreementSummaries/{agreementId} {
      allow create, update: if isAdmin() || hasAgreementAccess(agreementId);
      allow read: if isAdmin() || hasAgreementAccess(agreementId);
      allow delete: if false;
    }

    match /agreementCertificates/{agreementId} {
      allow create, update: if isAdmin() || hasAgreementAccess(agreementId);
      allow read: if isAdmin() || hasAgreementAccess(agreementId);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}