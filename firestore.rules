rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function agreementRoom(agreementId) {
      return get(/databases/$(database)/documents/agreementRooms/$(agreementId));
    }

    function hasAgreementAccess(agreementId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/agreementRooms/$(agreementId))
        && (
          isAdmin()
          ||
          agreementRoom(agreementId).data.founderId == request.auth.uid
          || agreementRoom(agreementId).data.investorId == request.auth.uid
          || request.auth.uid in agreementRoom(agreementId).data.adminIds
        );
    }

    function createsOwnAgreementRoom() {
      return isSignedIn()
        && (
          request.resource.data.founderId == request.auth.uid
          || request.resource.data.investorId == request.auth.uid
          || request.auth.uid in request.resource.data.adminIds
        );
    }

    function isBlockedBetween(firstUid, secondUid) {
      return exists(/databases/$(database)/documents/blockedUsers/$(firstUid + '_' + secondUid))
        || exists(/databases/$(database)/documents/blockedUsers/$(secondUid + '_' + firstUid));
    }

    function projectOwner(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId;
    }

    function opportunityOwner(opportunityId) {
      return exists(/databases/$(database)/documents/startupOpportunities/$(opportunityId))
        ? get(/databases/$(database)/documents/startupOpportunities/$(opportunityId)).data.founderId
        : get(/databases/$(database)/documents/investmentOpportunities/$(opportunityId)).data.founderId;
    }

    function startupOwner(startupId) {
      return exists(/databases/$(database)/documents/projects/$(startupId))
        ? projectOwner(startupId)
        : opportunityOwner(startupId);
    }

    function startupExists(startupId) {
      return exists(/databases/$(database)/documents/projects/$(startupId))
        || exists(/databases/$(database)/documents/startupOpportunities/$(startupId))
        || exists(/databases/$(database)/documents/investmentOpportunities/$(startupId));
    }

    function isV5Participant() {
      return isSignedIn()
        && resource != null
        && (
          resource.data.founderId == request.auth.uid
          || resource.data.investorId == request.auth.uid
        );
    }

    function createsV5ParticipantDocument() {
      return isSignedIn()
        && (
          request.resource.data.founderId == request.auth.uid
          || request.resource.data.investorId == request.auth.uid
        );
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    match /projects/{projectId} {
      allow read: if isSignedIn() || isAdmin();
      allow create: if isSignedIn()
        && (
          (
            request.resource.data.ownerId == request.auth.uid
            && request.resource.data.developerId == request.auth.uid
          )
          || request.resource.data.ownerId == request.auth.uid
          || request.resource.data.founderId == request.auth.uid
        );
      allow update, delete: if isAdmin()
        || (
          isSignedIn()
          && (
            resource.data.ownerId == request.auth.uid
            || resource.data.founderId == request.auth.uid
          )
        );
    }

    match /fundingRequests/{requestId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.requestedBy == request.auth.uid;
    }

    match /investments/{investmentId} {
      allow create: if isSignedIn()
        && (
          (
            request.resource.data.projectId != null
            && exists(/databases/$(database)/documents/projects/$(request.resource.data.projectId))
            && !isBlockedBetween(request.auth.uid, projectOwner(request.resource.data.projectId))
          )
          || request.resource.data.investorId == request.auth.uid
        );
      allow read, update: if isAdmin()
        || (isSignedIn() && (
          resource.data.investorId == request.auth.uid
          || resource.data.founderId == request.auth.uid
        ));
      allow delete: if false;
    }

    match /investmentOpportunities/{opportunityId} {
      allow read: if isSignedIn() || isAdmin();
      allow create: if isSignedIn() && request.resource.data.founderId == request.auth.uid;
      allow update: if isAdmin()
        || (
          isSignedIn()
          && (
            resource.data.founderId == request.auth.uid
            || request.resource.data.status in [
              'discussion_started',
              'ready_for_agreement',
              'agreement_pending',
              'awaiting_funding',
              'awaiting_payment',
              'funded',
              'completed'
            ]
          )
        );
      allow delete: if isAdmin() || (isSignedIn() && resource.data.founderId == request.auth.uid);
    }

    match /startupOpportunities/{opportunityId} {
      allow read: if isSignedIn() || isAdmin();
      allow create: if isSignedIn() && request.resource.data.founderId == request.auth.uid;
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.founderId == request.auth.uid)
        || (
          isSignedIn()
          && request.resource.data.status in [
            'discussion_started',
            'ready',
            'ready_for_agreement',
            'agreement_pending',
            'awaiting_funding',
            'funded',
            'completed'
          ]
        );
      allow delete: if isAdmin() || (isSignedIn() && resource.data.founderId == request.auth.uid);
    }

    match /discussionRooms/{roomId} {
      allow create: if request.auth != null
        && request.resource.data.investorId == request.auth.uid;
      allow read, update: if request.auth != null
        && (
          resource.data.founderId == request.auth.uid
          || resource.data.investorId == request.auth.uid
        );
      allow delete: if false;
    }

    match /discussionMessages/{messageId} {
      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid
        && exists(/databases/$(database)/documents/discussionRooms/$(request.resource.data.discussionRoomId))
        && (
          get(/databases/$(database)/documents/discussionRooms/$(request.resource.data.discussionRoomId)).data.founderId == request.auth.uid
          || get(/databases/$(database)/documents/discussionRooms/$(request.resource.data.discussionRoomId)).data.investorId == request.auth.uid
        );
      allow read: if isAdmin()
        || (
          isSignedIn()
          && exists(/databases/$(database)/documents/discussionRooms/$(resource.data.discussionRoomId))
          && (
            get(/databases/$(database)/documents/discussionRooms/$(resource.data.discussionRoomId)).data.founderId == request.auth.uid
            || get(/databases/$(database)/documents/discussionRooms/$(resource.data.discussionRoomId)).data.investorId == request.auth.uid
          )
        );
      allow update, delete: if false;
    }

    match /interests/{interestId} {
      allow create: if isSignedIn()
        && request.resource.data.investorId == request.auth.uid
        && request.resource.data.interestId == interestId
        && request.resource.data.status == 'interested'
        && startupExists(request.resource.data.startupOpportunityId)
        && request.resource.data.founderId == startupOwner(request.resource.data.startupOpportunityId)
        && !isBlockedBetween(request.auth.uid, request.resource.data.founderId);
      allow read: if isAdmin()
        || (isSignedIn() && (
          resource.data.investorId == request.auth.uid
          || resource.data.founderId == request.auth.uid
        ));
      allow update: if isAdmin()
        || (
          isSignedIn()
          && (
            resource.data.founderId == request.auth.uid
            || resource.data.investorId == request.auth.uid
          )
          && request.resource.data.status in ['discussion', 'accepted', 'expired']
        );
      allow delete: if false;
    }

    match /investmentInterests/{interestId} {
      allow create: if isSignedIn()
        && request.resource.data.investorId == request.auth.uid
        && request.resource.data.status == 'interested'
        && startupExists(request.resource.data.startupId)
        && request.resource.data.founderUid == startupOwner(request.resource.data.startupId)
        && !isBlockedBetween(request.auth.uid, request.resource.data.founderUid);
      allow read: if isAdmin()
        || (isSignedIn() && (
          resource.data.investorId == request.auth.uid
          || resource.data.founderUid == request.auth.uid
        ));
      allow update: if isAdmin()
        || (
          isSignedIn()
          && (
            resource.data.founderUid == request.auth.uid
            || resource.data.investorId == request.auth.uid
          )
          && request.resource.data.status in ['accepted', 'expired']
        );
      allow delete: if false;
    }

    match /matches/{matchId} {
      allow create: if isSignedIn()
        && (
          request.resource.data.founderUid == request.auth.uid
          || request.resource.data.investorUid == request.auth.uid
        )
        && startupExists(request.resource.data.startupId)
        && request.resource.data.founderUid == startupOwner(request.resource.data.startupId)
        && !isBlockedBetween(request.resource.data.founderUid, request.resource.data.investorUid);
      allow read, update: if isAdmin()
        || (isSignedIn() && (
          resource.data.founderUid == request.auth.uid
          || resource.data.investorUid == request.auth.uid
        ));
      allow delete: if false;
    }

    match /blockedUsers/{blockId} {
      allow create: if isSignedIn() && request.resource.data.blockerUid == request.auth.uid;
      allow read: if isAdmin() || (isSignedIn() && resource.data.blockerUid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /userReports/{reportId} {
      allow create: if isSignedIn() && request.resource.data.reporterUid == request.auth.uid;
      allow read, update: if isAdmin() || (isSignedIn() && resource.data.reporterUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if isSignedIn() && request.resource.data.reporterUid == request.auth.uid;
      allow read, update: if isAdmin() || (isSignedIn() && resource.data.reporterUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /agreementRooms/{agreementId} {
      allow create: if createsOwnAgreementRoom();
      allow read, update: if isAdmin() || hasAgreementAccess(agreementId);
      allow delete: if false;
    }

    match /agreements/{agreementId} {
      allow create: if createsOwnAgreementRoom() || createsV5ParticipantDocument();
      allow read, update: if isAdmin() || hasAgreementAccess(agreementId) || isV5Participant();
      allow delete: if false;
    }

    match /investmentContracts/{agreementId} {
      allow create, read, update: if isAdmin() || hasAgreementAccess(agreementId);
      allow delete: if false;
    }

    match /investmentContractVersions/{versionId} {
      allow create: if isSignedIn() && hasAgreementAccess(request.resource.data.agreementId);
      allow read: if isAdmin() || hasAgreementAccess(resource.data.agreementId);
      allow update, delete: if false;
    }

    match /agreementMeetings/{meetingId} {
      allow create: if isSignedIn() && hasAgreementAccess(request.resource.data.agreementId);
      allow read, update: if isAdmin() || hasAgreementAccess(resource.data.agreementId);
      allow delete: if false;
    }

    match /agreementParticipants/{participantId} {
      allow create: if isSignedIn() && hasAgreementAccess(request.resource.data.agreementId);
      allow read, update: if isAdmin() || hasAgreementAccess(resource.data.agreementId);
      allow delete: if false;
    }

    match /agreementTranscripts/{transcriptId} {
      allow create: if isSignedIn() && hasAgreementAccess(request.resource.data.agreementId);
      allow read, update: if isAdmin() || hasAgreementAccess(resource.data.agreementId);
      allow delete: if false;
    }

    match /agreementSummaries/{agreementId} {
      allow create, update: if isAdmin() || hasAgreementAccess(agreementId);
      allow read: if isAdmin() || hasAgreementAccess(agreementId);
      allow delete: if false;
    }

    match /agreementCertificates/{agreementId} {
      allow create, update: if isAdmin() || hasAgreementAccess(agreementId);
      allow read: if isAdmin() || hasAgreementAccess(agreementId);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}