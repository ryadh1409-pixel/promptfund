rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow create, read, update: if isUser(userId);
      allow delete: if false;
    }

    match /projects/{projectId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /fundingRequests/{requestId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.requestedBy == request.auth.uid;
    }

    match /investments/{investmentId} {
      allow create: if isSignedIn();
      allow read, update: if isSignedIn() && resource.data.investorId == request.auth.uid;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}